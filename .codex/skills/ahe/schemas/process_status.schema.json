{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AHE Process Status",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "current_command": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_step": {
      "type": [
        "string",
        "null"
      ]
    },
    "workflow_complete": {
      "type": "boolean"
    },
    "environment": {
      "type": "object",
      "properties": {
        "language": {
          "type": "string"
        },
        "detected_from_workspace": {
          "type": "boolean"
        }
      },
      "required": [
        "language",
        "detected_from_workspace"
      ]
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": [
            "string",
            "null"
          ]
        },
        "objectives": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "objectives"
      ]
    },
    "product": {
      "type": "object",
      "properties": {
        "spec_path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "complete": {
          "type": "boolean"
        }
      },
      "required": [
        "spec_path",
        "exists",
        "complete"
      ]
    },
    "files": {
      "type": "object",
      "properties": {
        "AGENTS.md": {
          "$ref": "#/definitions/fileStatus"
        },
        "docs/PRODUCT.md": {
          "$ref": "#/definitions/fileStatus"
        },
        "PROGRESS.md": {
          "$ref": "#/definitions/fileStatus"
        },
        "SESSION-HANDOFF.md": {
          "$ref": "#/definitions/fileStatus"
        },
        "init.sh": {
          "$ref": "#/definitions/fileStatus"
        },
        "feature-list.json": {
          "$ref": "#/definitions/fileStatus"
        }
      },
      "required": [
        "AGENTS.md",
        "docs/PRODUCT.md",
        "PROGRESS.md",
        "SESSION-HANDOFF.md",
        "init.sh",
        "feature-list.json"
      ]
    },
    "updated_at": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "mode",
    "current_command",
    "current_step",
    "workflow_complete",
    "environment",
    "project",
    "product",
    "files",
    "updated_at"
  ],
  "definitions": {
    "fileStatus": {
      "type": "object",
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "complete": {
          "type": "boolean"
        }
      },
      "required": [
        "exists",
        "complete"
      ]
    }
  }
}
