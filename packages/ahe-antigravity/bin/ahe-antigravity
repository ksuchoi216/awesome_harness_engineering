#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "${SCRIPT_PATH}" ]; do
  SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
  SCRIPT_PATH="$(readlink "${SCRIPT_PATH}")"
  case "${SCRIPT_PATH}" in
    /*) ;;
    *) SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_PATH}" ;;
  esac
done

readonly SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
readonly PACKAGE_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"
readonly SOURCE_SKILLS_DIR="${PACKAGE_ROOT}/skills"

usage() {
  cat <<'EOF'
Usage:
  ahe-antigravity install [--force]
  ahe-antigravity uninstall
  ahe-antigravity doctor
EOF
}

install_skill() {
  local force="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --force)
        force="true"
        ;;
      --backup)
        # Ignored for Antigravity, but accepted for compatibility with root script
        ;;
      *)
        printf 'Unknown install option: %s\n' "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
    shift
  done

  if [ ! -d "${SOURCE_SKILLS_DIR}" ]; then
    printf 'Packaged skill files are missing: %s\n' "${SOURCE_SKILLS_DIR}" >&2
    exit 1
  fi

  # Determine target directory
  local target_skills_dir="${HOME}/.gemini/config/skills"
  
  # For Antigravity, we currently only have one skill to install
  local skill_name="ahe-executor"
  local skill_target="${target_skills_dir}/${skill_name}"

  if [ -e "${skill_target}" ]; then
    if [ "${force}" != "true" ]; then
      cat <<EOF >&2
AHE Antigravity skill is already installed at:
  ${skill_target}

Re-run with --force to overwrite.
EOF
      exit 1
    else
      rm -rf "${skill_target}"
    fi
  fi

  mkdir -p "${target_skills_dir}"
  cp -R "${SOURCE_SKILLS_DIR}/${skill_name}" "${target_skills_dir}/${skill_name}"

  cat <<EOF
AHE Antigravity skill installed at:
  ${skill_target}
EOF
}

doctor() {
  local target_skills_dir="${HOME}/.gemini/config/skills"
  local skill_name="ahe-executor"

  if [ ! -f "${target_skills_dir}/${skill_name}/SKILL.md" ]; then
    printf 'Missing: %s/%s/SKILL.md\n' "${target_skills_dir}" "${skill_name}" >&2
    exit 1
  fi

  printf 'AHE Antigravity skill installation looks healthy.\n'
}

uninstall_skill() {
  local target_skills_dir="${HOME}/.gemini/config/skills"
  local skill_name="ahe-executor"
  local skill_target="${target_skills_dir}/${skill_name}"

  echo "Uninstalling AHE Antigravity skill from ${skill_target}..."
  rm -rf "${skill_target}"
  echo "AHE Antigravity skill uninstalled successfully."
}

main() {
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi

  local command="$1"
  shift

  case "${command}" in
    install)
      install_skill "$@"
      ;;
    uninstall)
      uninstall_skill
      ;;
    doctor)
      doctor
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown command: %s\n' "${command}" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
